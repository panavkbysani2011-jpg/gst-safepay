// GST SafePay — data model.
// Money is stored as Float (rupees) for the prototype; switch to integer paise
// or Decimal before handling real money. Dates are ISO "YYYY-MM-DD" strings to
// match the deterministic rule engine in lib/rules.
// Multi-tenant: every row is scoped by ownerId (the Supabase auth user id).
// Composite primary key (ownerId, id) isolates each account's data and lets two
// accounts each use the same business id (e.g. "v1") without colliding.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Vendor {
  ownerId         String
  id              String
  name            String
  gstin           String
  gstinActive     Boolean  @default(true)
  udyamRegistered Boolean  @default(false)
  udyamCategory   String? // "micro" | "small" | "medium" | null
  bills           Bill[]
  createdAt       DateTime @default(now())

  @@id([ownerId, id])
}

model Bill {
  ownerId               String
  id                    String
  vendor                Vendor   @relation(fields: [ownerId, vendorId], references: [ownerId, id], onDelete: Cascade)
  vendorId              String
  invoiceAcceptanceDate String // ISO date
  amount                Float
  hasWrittenAgreement   Boolean  @default(true)
  agreedPaymentDays     Int?
  paidDate              String? // ISO date or null
  createdAt             DateTime @default(now())

  @@id([ownerId, id])
  @@index([ownerId, vendorId])
}
