// GST SafePay — data model.
// Money is stored as Float (rupees) for the prototype; switch to integer paise
// or Decimal before handling real money. Dates are ISO "YYYY-MM-DD" strings to
// match the deterministic rule engine in lib/rules.
// Multi-tenant: every row is scoped by ownerId (the Supabase auth user id).
// Composite primary key (ownerId, id) isolates each account's data and lets two
// accounts each use the same business id (e.g. "v1") without colliding.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Vendor {
  ownerId         String
  id              String
  name            String
  gstin           String
  gstinActive     Boolean  @default(true)
  udyamRegistered Boolean  @default(false)
  udyamCategory   String? // "micro" | "small" | "medium" | null
  lastVerifiedDate String? // ISO date the GSTIN/Udyam was last confirmed (Module 4), or null
  bills           Bill[]
  createdAt       DateTime @default(now())

  @@id([ownerId, id])
}

model Bill {
  ownerId               String
  id                    String
  vendor                Vendor   @relation(fields: [ownerId, vendorId], references: [ownerId, id], onDelete: Cascade)
  vendorId              String
  invoiceAcceptanceDate String // ISO date
  amount                Float
  hasWrittenAgreement   Boolean  @default(true)
  agreedPaymentDays     Int?
  paidDate              String? // ISO date or null
  createdAt             DateTime @default(now())

  @@id([ownerId, id])
  @@index([ownerId, vendorId])
}

// Module 2 — GST IMS (Invoice Management System) supplier invoices.
// vendorName is denormalized (these suppliers need not exist in Vendor).
model ImsInvoice {
  ownerId      String
  id           String
  vendorId     String
  vendorName   String
  invoiceNo    String
  taxPeriod    String // "YYYY-MM"
  taxableValue Float
  gstAmount    Float
  imsAction    String // "accept" | "reject" | "pending" | "none"
  eligibility  String // "eligible" | "ineligible" | "unsure"
  createdAt    DateTime @default(now())

  @@id([ownerId, id])
}

// Module 3 — RCM (Reverse Charge Mechanism) purchases.
// vendorName is denormalized (unregistered suppliers need not exist in Vendor).
model RcmPurchase {
  ownerId              String
  id                   String
  vendorId             String
  vendorName           String
  supplierUnregistered Boolean
  supplyType           String // "goods" | "services"
  supplyDate           String // ISO date
  rcmTaxAmount         Float
  selfInvoiceIssued    Boolean  @default(false)
  rcmTaxPaidDate       String? // ISO date or null
  createdAt            DateTime @default(now())

  @@id([ownerId, id])
}

// Module 5 — statutory compliance deadlines + evidence (proof-of-filing metadata).
model ComplianceDeadline {
  ownerId   String
  id        String
  name      String // e.g. "GSTR-3B"
  authority String // e.g. "GST" | "TDS" | "PF/ESI" | "MCA/ROC" | "POSH"
  period    String // e.g. "2026-06" or "FY2025-26"
  dueDate   String // ISO
  filedDate String? // ISO once filed, else null
  proofRef  String? // ARN / challan no. / URL — the evidence
  createdAt DateTime @default(now())

  @@id([ownerId, id])
}
