// GST SafePay — data model.
// Money is stored as Decimal(14,2) rupees — exact to the paise, no float drift.
// The rule engines still compute in JS numbers (derived interest/deduction are
// approximations that get rounded for display); the stored source-of-truth
// amounts are exact. Prisma returns these columns as Decimal, converted to
// number at the data-read boundary (lib/data/dashboard.ts, the export route).
// Dates are ISO "YYYY-MM-DD" strings to match the deterministic rule engine.
// Multi-tenant: every row is scoped by ownerId (the Supabase auth user id).
// Composite primary key (ownerId, id) isolates each account's data and lets two
// accounts each use the same business id (e.g. "v1") without colliding.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Vendor {
  ownerId         String
  id              String
  name            String
  gstin           String
  gstinActive     Boolean  @default(true)
  udyamRegistered Boolean  @default(false)
  udyamCategory   String? // "micro" | "small" | "medium" | null
  lastVerifiedDate String? // ISO date the GSTIN/Udyam was last confirmed (Module 4), or null
  bills           Bill[]
  createdAt       DateTime @default(now())

  @@id([ownerId, id])
}

model Bill {
  ownerId               String
  id                    String
  vendor                Vendor   @relation(fields: [ownerId, vendorId], references: [ownerId, id], onDelete: Cascade)
  vendorId              String
  invoiceAcceptanceDate String // ISO date
  amount                Decimal  @db.Decimal(14, 2) // rupees, exact to the paise
  hasWrittenAgreement   Boolean  @default(true)
  agreedPaymentDays     Int?
  paidDate              String? // ISO date or null
  createdAt             DateTime @default(now())

  @@id([ownerId, id])
  @@index([ownerId, vendorId])
}

// Module 2 — GST IMS (Invoice Management System) supplier invoices.
// vendorName is denormalized (these suppliers need not exist in Vendor).
model ImsInvoice {
  ownerId      String
  id           String
  vendorId     String
  vendorName   String
  invoiceNo    String
  taxPeriod    String // "YYYY-MM"
  taxableValue Decimal @db.Decimal(14, 2) // rupees, exact to the paise
  gstAmount    Decimal @db.Decimal(14, 2) // rupees, exact to the paise
  imsAction    String // "accept" | "reject" | "pending" | "none"
  eligibility  String // "eligible" | "ineligible" | "unsure"
  createdAt    DateTime @default(now())

  @@id([ownerId, id])
}

// Module 3 — RCM (Reverse Charge Mechanism) purchases.
// vendorName is denormalized (unregistered suppliers need not exist in Vendor).
model RcmPurchase {
  ownerId              String
  id                   String
  vendorId             String
  vendorName           String
  supplierUnregistered Boolean
  supplyType           String // "goods" | "services"
  supplyDate           String // ISO date
  rcmTaxAmount         Decimal  @db.Decimal(14, 2) // rupees, exact to the paise
  selfInvoiceIssued    Boolean  @default(false)
  rcmTaxPaidDate       String? // ISO date or null
  createdAt            DateTime @default(now())

  @@id([ownerId, id])
}

// Fixed-window rate-limit counters (Phase 4). Not tenant data — keyed by
// "action:ip" or "action:userId". Durable + shared across serverless instances,
// which in-memory limiting can't do on Vercel. Locked down in prisma/rls.sql.
model RateLimit {
  key         String   @id
  count       Int      @default(0)
  windowStart DateTime @default(now())
}

// Module 5 — statutory compliance deadlines + evidence (proof-of-filing metadata).
model ComplianceDeadline {
  ownerId   String
  id        String
  name      String // e.g. "GSTR-3B"
  authority String // e.g. "GST" | "TDS" | "PF/ESI" | "MCA/ROC" | "POSH"
  period    String // e.g. "2026-06" or "FY2025-26"
  dueDate   String // ISO
  filedDate String? // ISO once filed, else null
  proofRef  String? // ARN / challan no. / URL — the evidence reference
  proofFilePath String? // path in the private "compliance-proofs" Storage bucket, or null
  createdAt DateTime @default(now())

  @@id([ownerId, id])
}

// CA-config editor — per-owner overrides of the tax-rule parameters, stored as a
// validated JSON blob and resolved against the shipped defaults on read.
model RuleConfig {
  ownerId   String   @id
  values    Json
  updatedAt DateTime @updatedAt
}

// Business identity — optional firm name + GSTIN shown on the action report.
// One row per account.
model BusinessProfile {
  ownerId      String   @id
  businessName String?
  gstin        String?
  updatedAt    DateTime @updatedAt
}
