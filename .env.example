# Copy to .env and fill in. .env is gitignored (machine-local, per the continuity design).
# Supabase Postgres connection strings (Connect button -> ORMs/Prisma tab):
#   DATABASE_URL = transaction pooler (port 6543, ?pgbouncer=true) — app runtime
#   DIRECT_URL   = session pooler (port 5432) — Prisma migrations
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres"

# Supabase Auth — public keys (Project Settings -> API). Safe to expose (NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."

# Show the "Continue with Google" button. Set to "true" ONLY after the Google
# provider is enabled in Supabase (Authentication -> Providers -> Google) and the
# redirect URLs are allow-listed. See SETUP-AUTH.md. Left unset, the button is
# hidden so no one lands on Supabase's "provider is not enabled" error page.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED="false"

# --- Optional AI column-mapping on import ----------------------------------
# Off by default: imports use the deterministic column matcher only, and the
# client makes no AI request at all. Turn on by setting BOTH:
#   1. NEXT_PUBLIC_AI_MAPPING_ENABLED="1"  — public flag; lets the client ask.
#   2. NVIDIA_API_KEY                      — SECRET; server-only, never exposed.
# The server refuses to call the model unless the key is present, so the public
# flag alone cannot switch AI on.
#
# What is sent: only the uploaded file's column names and up to two truncated
# sample rows — never the whole file — so the model can SUGGEST which column
# feeds which field. It never computes a figure and nothing is saved until the
# user confirms. Keep this in step with the disclosure copy on the import page.
NEXT_PUBLIC_AI_MAPPING_ENABLED="0"
NVIDIA_API_KEY=""
# Optional overrides (default: NVIDIA's OpenAI-compatible endpoint + Kimi K2.6).
# Any OpenAI-compatible chat-completions endpoint works, e.g. a Gemini proxy.
# AI_MAPPING_ENDPOINT="https://integrate.api.nvidia.com/v1/chat/completions"
# AI_MAPPING_MODEL="moonshotai/kimi-k2.6"
