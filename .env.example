# Copy to .env and fill in. .env is gitignored (machine-local, per the continuity design).
# Supabase Postgres connection strings (Connect button -> ORMs/Prisma tab):
#   DATABASE_URL = transaction pooler (port 6543, ?pgbouncer=true) — app runtime
#   DIRECT_URL   = session pooler (port 5432) — Prisma migrations
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres"

# Supabase Auth — public keys (Project Settings -> API). Safe to expose (NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."
